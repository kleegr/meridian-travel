# Get your API key from https://console.cloud.google.com/
# Enable "Places API" and "Maps JavaScript API"
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# GHL OAuth (from your GHL Marketplace app)
NEXT_PUBLIC_GHL_APP_ID=your_ghl_app_id_here
NEXT_PUBLIC_GHL_CLIENT_ID=your_ghl_client_id_here
NEXT_PUBLIC_GHL_CLIENT_SECRET=your_ghl_client_secret_here

# GHL SSO key (from your GHL Marketplace app settings)
NEXT_PUBLIC_GHL_SSO_KEY=your_ghl_sso_key_here

# GHL Dev fallback (used when SSO isn't available, e.g. local testing outside GHL iframe)
NEXT_PUBLIC_GHL_LOCATION_ID=your_ghl_location_id_here
